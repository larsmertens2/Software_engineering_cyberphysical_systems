' This Plant UML diagram has been refactored and changed heavily by AI.

@startuml WarehouseSystem

skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
}
skinparam package {
    BackgroundColor #F0F0FF
    BorderColor Black
}

package "Frontend (SvelteKit)" {

    class Layout {
        - emergencyActive : bool
        --
        + toggleEmergency()
        + checkEmergencyStatus()
        ..WebSocket..
        on: emergency_updated
    }

    class QueuePage {
        - rawQueueData : array
        - newItemId : str
        --
        + refreshQueue()
        + handleSubmit()
        ..WebSocket..
        on: queue_updated
    }

    class InventoryPage {
        - items : array
        - searchTerm : str
        --
        + refreshInventory()
        ..WebSocket..
        on: inventory_updated
    }

    class MapPage {
        - mapData : nodes + edges
        - aisleStates : dict
        ..WebSocket..
        on: aisle_updated
    }

    Layout *-down- QueuePage     : /
    Layout *-down- InventoryPage : /inventory
    Layout *-down- MapPage       : /map
}

package "Flask Backend" {

    class FlaskAPI {
        - locked_nodes : dict
        - locked_aisles : dict
        - aisle_states : dict
        - emergency_active : bool
        --
        + GET /api/items
        + POST /api/queue
        + POST /api/queue/claim
        + POST /api/queue/complete
        + GET /api/queue/status
        + POST /api/queue/aisle/lock
        + GET /api/queue/aisle/locked
        + POST /api/queue/aisle/unlock
        + POST /api/queue/aisle/reset_all
        + POST /api/nodes/lock
        + POST /api/nodes/unlock
        + GET /api/nodes/locked
        + GET /api/map
        + POST /api/aisle/state
        + GET /api/aisle/states
        + GET /api/emergency
        + POST /api/emergency
    }

    class SocketIOEvents <<enumeration>> {
        queue_updated
        inventory_updated
        aisle_updated
        emergency_updated
    }

    FlaskAPI ..> SocketIOEvents : emits
}

package "Database" {

    class items {
        + id : int
        + name : str
        + category : str
        + stock : int
        + aisle : int
    }

    class job_queue {
        + id : int
        + item_id : int
        + status : pending | assigned | completed
        + robot_id : str | null
        + created_at : timestamp
    }

    job_queue "many" --> "1" items : item_id
}

package "Robot Controller" {

    class RobotController {
        - hal : RobotHAL
        - time_step : int
        - robot_name : str
        - taskmanager : TaskManager
        - state : str
        - current_node : str
        - route : list[str]
        - current_task : tuple | None
        - ReachedPackage : bool
        - obstructed_nodes : list[str]
        - current_locked_aisle : str | None
        - aisle_response : str | None
        - emergency_active : bool
        --
        + run()
        - _state_idle()
        - _state_waiting()
        - _state_rotating()
        - _state_moving()
        - _state_moving_aisle()
        - _state_waiting_aisle()
        - _navigate_to_waypoint(slow_factor)
        - _request_aisle_entry(node_name, current_node)
        - _notify_aisle_exit()
        - _poll_receiver()
        - _handle_obstacle(target_name)
        - _on_waypoint_reached(target_name)
        - _on_route_finished()
        - _check_emergency_status()
        - _transition(new_state)
        - _drive(left, right, slow_factor)
    }

    class RobotHAL {
        - _robot : Robot
        - _time_step : int
        --
        + get_name() : str
        + get_time() : float
        + get_time_step() : int
        + step(time_step) : int
        + getDevice(device_name) : object
    }

    package "Robot Hardware" {
        class GPS <<hardware>> {
            + enable(time_step)
            + get_position() : list[float]
        }
        class Compass <<hardware>> {
            + enable(time_step)
            + get_direction() : list[float]
        }
        class LIDAR <<hardware>> {
            + enable(time_step)
            + enablePointCloud()
            + get_range_image() : list[float]
        }
        class Motor <<hardware>> {
            + set_position_infinite()
            + setPosition(pos: float)
            + setVelocity(v: float)
        }
        class "Emitter (Robot)" as RobotEmitter <<hardware>> {
            + send(data: bytes)
        }
        class "Receiver (Robot)" as RobotReceiver <<hardware>> {
            + enable(time_step)
            + getQueueLength() : int
            + getString() : str
            + nextPacket()
        }
    }

    class sensors <<module>> {
        + get_direction(compass) : float
        + is_path_clear(lidar, threshold) : bool
        + detect_narrow_corridor(lidar) : bool
        + get_side_distances(lidar) : tuple
        + object_nearby(lidar, threshold) : bool
    }

    class motion <<module>> {
        + drive(left_motor, right_motor,\nleft_speed, right_speed,\nlidar, nearby_threshold, slow_factor)
    }

    class navigation <<module>> {
        + load_map() : (nodes, edges)
        + get_route(nodes, edges,\ncurrent, obstructed, end) : list[str]
    }

    class shortest_path <<module>> {
        + shortest_path(nodes, obstructed,\nedges, start, end) : list[str]
    }

    class TaskManager {
        - robot_name : str
        --
        + get_task_list(n) : list[tuple]
        + complete_task(task_id)
        + lock_aisle(aisle_name) : bool
        + unlock_aisle()
    }

    RobotController *-- RobotHAL : hal
    RobotHAL *-- GPS : gps
    RobotHAL *-- Compass : compass
    RobotHAL *-- LIDAR : lidar
    RobotHAL *-- Motor : left_motor / right_motor
    RobotHAL *-- RobotEmitter : emitter
    RobotHAL *-- RobotReceiver : receiver

    RobotController ..> sensors : uses
    RobotController ..> motion : uses
    RobotController ..> navigation : uses
    navigation ..> shortest_path : uses
    motion ..> sensors : object_nearby

    RobotController *-- TaskManager : taskmanager
}

package "Aisle Device Controller" {

    class AisleDeviceController {
        - aisle_id : str
        - locker : str | None
        - queue : list[dict]
        --
        + send_message(robot_id: str, msg: str)
        + update_state()
        + run()
    }

    note right of AisleDeviceController
      Webots instances:
      Aisle_1, Aisle_2, Aisle_3, Aisle_4
      queue entry: { robot_id, node }
    end note

    package "Aisle Device Hardware" {
        class "Emitter (Aisle)" as AisleEmitter <<hardware>> {
            + send(data: bytes)
        }
        class "Receiver (Aisle)" as AisleReceiver <<hardware>> {
            + enable(time_step)
            + getQueueLength() : int
            + getString() : str
            + nextPacket()
            + getChannel() : int
        }
    }

    AisleDeviceController *-- AisleEmitter : emitter
    AisleDeviceController *-- AisleReceiver : receiver
}

package "Message Protocol" {
    class RobotToAisle <<enumeration>> {
        REQUEST_ENTRY
        EXITING
    }
    class AisleToRobot <<enumeration>> {
        ENTRY_GRANTED
        ENTRY_DENIED
    }
    RobotToAisle -[hidden]right- AisleToRobot
}

' Frontend <-> Backend (HTTP + WebSocket)
QueuePage     ..> FlaskAPI : GET /api/queue/status\nPOST /api/queue
InventoryPage ..> FlaskAPI : GET /api/items
MapPage       ..> FlaskAPI : GET /api/map\nGET /api/aisle/states
Layout        ..> FlaskAPI : GET|POST /api/emergency

SocketIOEvents ..> Layout        : emergency_updated
SocketIOEvents ..> QueuePage     : queue_updated
SocketIOEvents ..> InventoryPage : inventory_updated
SocketIOEvents ..> MapPage       : aisle_updated

' Backend <-> Database
FlaskAPI --> items    : reads / updates stock
FlaskAPI --> job_queue : creates / updates status

' Robot <-> Backend (HTTP)
TaskManager ..> FlaskAPI : POST /api/queue/claim\nPOST /api/queue/complete\nPOST /api/queue/aisle/lock\nPOST /api/queue/aisle/unlock
RobotController ..> FlaskAPI : GET /api/emergency

' AisleDevice <-> Backend (HTTP)
AisleDeviceController ..> FlaskAPI : POST /api/aisle/state

' Robot <-> AisleDevice (Wireless)
RobotController -right-> AisleDeviceController : REQUEST_ENTRY / EXITING\n(via Emitter)
AisleDeviceController -left-> RobotController  : ENTRY_GRANTED / ENTRY_DENIED\n(via Emitter)

@enduml
