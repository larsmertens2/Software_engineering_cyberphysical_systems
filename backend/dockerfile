# Gebruik een lichte Python versie
FROM python:3.11-slim

# Zet de werkmap in de container
WORKDIR /app

# Kopieer de requirements eerst (voor betere caching)
COPY requirements.txt .

# Installeer de nodige Python pakketten
RUN pip install --no-cache-dir -r requirements.txt

# Kopieer de rest van de backend code
COPY . .

# Exposeer de poort waar Flask op draait
EXPOSE 5000

# Start de Flask applicatie
# We gebruiken 0.0.0.0 om de API bereikbaar te maken buiten de container
CMD ["python", "main.py"]